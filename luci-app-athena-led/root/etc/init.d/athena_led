#!/bin/sh /etc/rc.common

START=99
STOP=99
USE_PROCD=1
PROG=/usr/bin/athena-led

check_binary() {
    [ -x "$PROG" ] || return 1
}

# 🌟 解析单模式表格：全部拼接成一个巨长的字符串
single_str=""
parse_single() {
    local cfg="$1"
    local module duration
    config_get module "$cfg" 'module' ''
    config_get duration "$cfg" 'duration' '5'
    [ -z "$module" ] && return
    local str="${module}#${duration}"
    single_str="${single_str}${single_str:+ }${str}"
}

# 🌟 解析多模式表格：分别放进 8 个独立频道的变量里
local chan_1="" local chan_2="" local chan_3="" local chan_4=""
local chan_5="" local chan_6="" local chan_7="" local chan_8=""
parse_multi() {
    local cfg="$1"
    local channel module duration
    config_get channel "$cfg" 'channel' '1'
    config_get module "$cfg" 'module' ''
    config_get duration "$cfg" 'duration' '5'
    [ -z "$module" ] && return
    local str="${module}#${duration}"
    eval "chan_${channel}=\"\${chan_${channel}}\${chan_${channel}:+ }\${str}\""
}

start_service() {
    config_load 'athena_led'
    local cfg='general' 

    local enabled
    config_get_bool enabled "$cfg" 'enabled' '0'
    [ "$enabled" -eq 0 ] && return 1

    check_binary || return 1

    # ... [读取你的 lightLevel, weatherFormat 等基础配置] ...
    local profileMode
    config_get profileMode "$cfg" 'profile_mode' 'multi'

    procd_open_instance
    procd_set_param command "$PROG"
    
    # ==========================================
    # 🌟 核心分流：根据模式生成对应的 --profile 参数
    # ==========================================
    procd_append_param command --profile
    local has_profile=0

    if [ "$profileMode" = "single" ]; then
        # 单模式：读取 single_module 表格，生成 1 个字符串
        config_foreach parse_single 'single_module'
        if [ -n "$single_str" ]; then
            procd_append_param command "$single_str"
            has_profile=1
        fi
    else
        # 多模式：读取 multi_module 表格，生成多个字符串
        config_foreach parse_multi 'multi_module'
        for i in 1 2 3 4 5 6 7 8; do
            eval "local val=\"\$chan_$i\""
            if [ -n "$val" ]; then
                procd_append_param command "$val"
                has_profile=1
            fi
        done
    fi

    # 防呆兜底
    if [ "$has_profile" -eq 0 ]; then
        procd_append_param command "time_sec#10 weather#10" "cpu#5 mem#5 temp#5"
    fi

    # 基础与模块配置
    config_get lightLevel "$cfg" 'light_level' '5'
    config_get netInterface "$cfg" 'net_interface' 'br-lan'
    config_get ipUrl "$cfg" 'wan_ip_custom_url' 'http://checkip.amazonaws.com'
    config_get customText "$cfg" 'custom_content' 'Roc-Gateway'
    config_get url "$cfg" 'http_url' ''
    config_get httpLength "$cfg" 'http_length' '15'
    config_get httpCacheSecs "$cfg" 'http_cache_secs' '60'       # ✅ 补齐缓存时间
    config_get weatherCity "$cfg" 'weather_city' 'auto'
    config_get weatherSource "$cfg" 'weather_source' 'uapis'
    config_get weatherFormat "$cfg" 'weather_format' 'simple'
    config_get seniverseKey "$cfg" 'seniverse_key' ''
    config_get tempFlag "$cfg" 'temp_sensors' '0 1 2 3 4'
    config_get stockUrl "$cfg" 'stock_url' ''                    # ✅ 补齐股票URL

    # 定时配置
    config_get_bool enableSleep "$cfg" 'enable_sleep' '0'
    config_get sleepStart "$cfg" 'off_time' ''
    config_get sleepEnd "$cfg" 'on_time' ''

    # 全局 LED 状态灯独立开关 (Bool 类型)
    config_get_bool disableLedClock "$cfg" 'disable_led_clock' '0'
    config_get_bool disableLedMedal "$cfg" 'disable_led_medal' '0'
    config_get_bool disableLedUp "$cfg" 'disable_led_up' '0'
    config_get_bool disableLedDown "$cfg" 'disable_led_down' '0'

    if [ "$enableSleep" -eq 0 ]; then
        sleepStart=""
        sleepEnd=""
    fi

    # --- 2. 启动实例与拼接参数 ---
    procd_open_instance
    procd_set_param command "$PROG"
    
    # 组装 --profile 动态数组
    procd_append_param command --profile
    local has_profile=$(uci -q get athena_led.general.profile)
    if [ -n "$has_profile" ]; then
        config_list_foreach "$cfg" 'profile' append_profile
    else
        procd_append_param command "time_sec#10 weather#10" "cpu#5 mem#5 temp#5" "traffic_split#5 nic#5" "banner#10"
    fi

    # 追加基础参数
    procd_append_param command --light-level "$lightLevel"
    procd_append_param command --net-interface "$netInterface"
    procd_append_param command --ip-url "$ipUrl"
    procd_append_param command --custom-text "$customText"
    procd_append_param command --custom-http-url "$url"
    procd_append_param command --http-length "$httpLength"
    procd_append_param command --http-cache-secs "$httpCacheSecs"  # ✅ 新增
    procd_append_param command --weather-city "$weatherCity"
    procd_append_param command --weather-source "$weatherSource"
    procd_append_param command --seniverse-key "$seniverseKey"
    procd_append_param command --weather-format "$weatherFormat"
    procd_append_param command --temp-flag "$tempFlag"
    procd_append_param command --stock-url "$stockUrl"             # ✅ 新增
    
    # 追加定时参数
    procd_append_param command --sleep-start "$sleepStart"
    procd_append_param command --sleep-end "$sleepEnd"

    # ✅ 补齐 LED 独立开关判断逻辑
    # 如果值为 1，则追加该参数（Rust 只要看到参数就会设为 true）
    [ "$disableLedClock" -eq 1 ] && procd_append_param command --disable-led-clock
    [ "$disableLedMedal" -eq 1 ] && procd_append_param command --disable-led-medal
    [ "$disableLedUp" -eq 1 ] && procd_append_param command --disable-led-up
    [ "$disableLedDown" -eq 1 ] && procd_append_param command --disable-led-down

    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "athena_led"
}